# --- Supabase (configured in step 5) ---------------------------------------
# Project Settings > API Keys in your Supabase dashboard.
# Supabase is migrating from "anon key" to "publishable key" naming (same
# purpose: a low-privilege, client-safe key protected by Row Level Security).
# If your project only shows a legacy "anon" key, paste that value here —
# it works identically in this slot.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# --- Site -------------------------------------------------------------------
# Used for canonical URLs, sitemap, and Open Graph metadata (step 7).
# Replace with the real production domain before deploying.
NEXT_PUBLIC_SITE_URL=https://www.learn-japanese-with-lisa.com
